# AKShare API Token
# 从雪球获取数据的token
AKSHARE_TOKEN=your_akshare_token_here

# 数据库配置
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=xxxx
PG_USER=postgres
PG_PASSWORD=xxxx

# 自动更新K线配置
AUTO_UPDATE_KLINE=true

# K线更新范围配置（true: 更新所有股票，false: 只更新监控股票）
UPDATE_ALL_STOCKS=false

# K线更新并发数配置（默认50，建议范围：10-100）
KLINE_UPDATE_CONCURRENT=50

# 自动更新股票列表配置
AUTO_UPDATE_STOCK_LIST=true

# 自动更新行业板块配置
AUTO_UPDATE_INDUSTRY_BOARD=true

# OpenAI-compatible 大模型配置（用于价格行为分析）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
